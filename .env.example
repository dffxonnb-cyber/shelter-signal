# Server-only PostgreSQL connection string for Vercel API routes.
# Never expose this to frontend code and never prefix it with VITE_.
DATABASE_URL=postgresql://shelter_signal:shelter_signal@localhost:5432/shelter_signal

# Server-only data.go.kr service key for backend/API or ingestion usage.
# Never expose this to frontend code and never prefix it with VITE_.
DATA_GO_KR_SERVICE_KEY=your_data_go_kr_service_key_here

# Optional server-only normalized notice cache TTL. Use 0 to disable; max 600.
NOTICES_CACHE_TTL_SECONDS=300

# Legacy local ingestion scripts may still read this name.
ANIMAL_API_KEY=your_data_go_kr_service_key_here
